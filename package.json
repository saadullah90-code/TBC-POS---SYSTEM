{
  "name": "branx-pos",
  "version": "1.0.0",
  "license": "MIT",
  "private": true,
  "description": "BranX* Retail POS + Inventory + Barcode System",
  "workspaces": [
    "lib/*",
    "artifacts/*",
    "scripts"
  ],
  "scripts": {
    "dev": "concurrently --names \"API,WEB\" --prefix-colors \"cyan,magenta\" --kill-others-on-fail \"npm run dev --workspace @workspace/api-server\" \"npm run dev --workspace @workspace/pos-system\"",
    "build": "npm run typecheck && npm run build --workspaces --if-present",
    "typecheck:libs": "tsc --build",
    "typecheck": "npm run typecheck:libs && npm run typecheck --workspaces --if-present",
    "db:push": "npm run push --workspace @workspace/db",
    "db:seed": "npm run seed --workspace @workspace/scripts",
    "setup": "npm install && npm run db:push && npm run db:seed",
    "start": "concurrently --names \"API,WEB\" --prefix-colors \"cyan,magenta\" --kill-others-on-fail \"npm run start --workspace @workspace/api-server\" \"npm run serve --workspace @workspace/pos-system\""
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  },
  "optionalDependencies": {
    "@esbuild/darwin-arm64": "0.27.3",
    "@esbuild/darwin-x64": "0.27.3",
    "@esbuild/linux-x64": "0.27.3",
    "@esbuild/win32-x64": "0.27.3",
    "@rollup/rollup-darwin-arm64": "4.59.0",
    "@rollup/rollup-darwin-x64": "4.59.0",
    "@rollup/rollup-linux-x64-gnu": "4.59.0",
    "@rollup/rollup-win32-x64-msvc": "4.59.0"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "dotenv": "^17.4.2"
  }
}
