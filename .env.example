# ─────────────────────────────────────────────────────────────────────
# BranX POS — Environment Variables (template)
# Copy values into Railway / your hosting provider as actual env vars.
# This file documents what the app reads. Do NOT commit a real `.env`.
# ─────────────────────────────────────────────────────────────────────

# ── Database (REQUIRED) ──────────────────────────────────────────────
# Postgres connection string. In dev we use SUPABASE_DATABASE_URL.
# In Railway production, set DATABASE_URL to your prod Postgres URL.
SUPABASE_DATABASE_URL=postgresql://user:pass@host:5432/dbname
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# ── Session secret (REQUIRED) ────────────────────────────────────────
# Long random string used to sign session cookies. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# WARNING: changing this logs out every existing user.
SESSION_SECRET=replace-with-a-long-random-hex-string

# ── Hidden Owner Console URL (RECOMMENDED OVERRIDE FOR PROD) ─────────
# The super-admin "Owner Console" is mounted under this slug on BOTH
# the API and the frontend so the URL itself is unguessable.
# Both vars MUST be the same value. Change them together.
# Default (if unset): brx-control-x9k2p7m4
OWNER_PORTAL_SLUG=brx-control-x9k2p7m4
VITE_OWNER_PORTAL_SLUG=brx-control-x9k2p7m4

# ── Server port (set automatically on Railway / Replit) ──────────────
# PORT=3001
