# Copy this file to ".env" and fill in your values.
# On Windows: in PowerShell run  Copy-Item .env.example .env

# ---- Database (REQUIRED) ----
# Postgres connection string. Use Supabase, Neon, or a local Postgres.
# Supabase example:
#   DATABASE_URL=postgres://postgres.xxxxx:PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres
DATABASE_URL=

# ---- Session (REQUIRED) ----
# Any random string (32+ chars). Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-string

# ---- Optional ----
# API server port (default 3001)
# PORT=3001
# Web app dev server port (default 5173)
# Note: PORT is shared; if running api+web together via "npm run dev",
# leave PORT unset so each picks its default.
