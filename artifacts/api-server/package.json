    "pino-http": "^10.0.0"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.19.0",
    "@types/node": "^25.3.3",
    "esbuild": "^0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
